{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": false,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,

    "baseUrl": ".",

    "ignoreDeprecations": "6.0",

    "types": ["react", "react-dom", "react-native"]
  },
  "include": ["**/*.ts", "**/*.tsx"]
}